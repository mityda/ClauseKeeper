# ClauseKeeper environment configuration
# Copy this file to .env for local Docker/self-hosted runs.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Required for self-hosting
# -----------------------------------------------------------------------------

# Secret used to sign session cookies. Change this for any shared/public instance.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=change-me-generate-a-long-random-secret

# Public URL users open in their browser. Used for redirects and cookie security.
APP_BASE_URL=http://localhost:8000

# SQLite database location. The Docker image defaults this to /data/clausekeeper.db
# and docker-compose mounts /data as a persistent named volume.
CLAUSEKEEPER_DB=/data/clausekeeper.db

# Optional in Docker; the image defaults to 8000 and compose maps localhost:8000.
PORT=8000

# -----------------------------------------------------------------------------
# Optional (cloud/paid features)
# -----------------------------------------------------------------------------

# Leave STRIPE_SECRET_KEY blank/unset to run free self-hosted mode.
# In no-Stripe mode, Stripe billing is disabled and local email login/dev subscription
# flows keep the scanner and generator usable without paid keys.
STRIPE_SECRET_KEY=

# Stripe subscription price IDs. Required only when STRIPE_SECRET_KEY is set.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Legacy monthly price fallback still read by the app when STRIPE_PRICE_ID_MONTHLY
# is not set. Prefer STRIPE_PRICE_ID_MONTHLY for new installs.
STRIPE_PRICE_ID=

# Stripe webhook signing secret. Required only for /webhook/stripe in Stripe mode.
STRIPE_WEBHOOK_SECRET=

# Legacy database env var read as a fallback for old deployments.
# Prefer CLAUSEKEEPER_DB for new installs.
POLICYFRESH_DB=
