# ClauseKeeper environment configuration — copy to `.env` and fill in for production.
# DO NOT commit a real .env with secrets.

# --- Stripe (REQUIRED to take real payments) ---
# Create these in your Stripe dashboard. With STRIPE_SECRET_KEY set, /subscribe
# creates a real Checkout Session and /webhook/stripe flips per-user subscriptions.
# Leave STRIPE_SECRET_KEY unset to run in dev/no-Stripe mode (local flag + email login).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
# Legacy monthly fallback: STRIPE_PRICE_ID still works if STRIPE_PRICE_ID_MONTHLY is unset.
# STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- App ---
# Secret used to sign session cookies (itsdangerous). MUST be set in production.
APP_SECRET_KEY=dev-insecure-change-me
# Public base URL, used to build Stripe success/cancel/return URLs.
APP_BASE_URL=http://127.0.0.1:8000
# SQLite path. (Legacy POLICYFRESH_DB is still read as a fallback.)
CLAUSEKEEPER_DB=./clausekeeper.db
